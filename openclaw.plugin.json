{
  "id": "telegram-userbot",
  "name": "Telegram Userbot",
  "description": "Connect your personal Telegram account to OpenClaw via MTProto. Your AI assistant responds as you.",
  "version": "0.1.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channels": ["telegram-userbot"],
  "channelConfigs": {
    "telegram-userbot": {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "allowFrom": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                }
              ]
            }
          },
          "groupPolicy": {
            "type": "string",
            "enum": [
              "open",
              "mention"
            ],
            "default": "mention"
          },
          "accounts": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "apiId": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    {
                      "type": "string",
                      "pattern": "^[1-9][0-9]*$"
                    }
                  ]
                },
                "apiHash": {
                  "type": "string"
                },
                "sessionString": {
                  "type": "string"
                },
                "allowFrom": {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  }
                },
                "groupPolicy": {
                  "type": "string",
                  "enum": [
                    "open",
                    "mention"
                  ],
                  "default": "mention"
                }
              },
              "required": [
                "apiId",
                "apiHash",
                "sessionString"
              ]
            }
          }
        }
      }
    }
  }
}
